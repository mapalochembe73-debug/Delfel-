.process-item:hover { background: var(--surface); }

.process-num {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--accent);
  min-width: 40px;
  padding-top: 0.2rem;
  letter-spacing: 0.1em;
}

.process-content h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; }

.process-content p {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--muted);
  line-height: 1.7;
}

.contact-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.contact-info p {
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.8;
  margin-bottom: 2rem;
}

.contact-detail { display: flex; flex-direction: column; gap: 0.8rem; }

.contact-row {
  display: flex;
  gap: 1rem;
  align-items: center;
  font-family: var(--mono);
  font-size: 0.75rem;
}

.contact-row .label { color: var(--muted); min-width: 80px; }
.contact-row .value { color: var(--text); }

.contact-form { display: flex; flex-direction: column; gap: 1rem; }

.form-group { display: flex; flex-direction: column; gap: 0.4rem; }

.form-group label {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.form-group input,
.form-group textarea,
.form-group select {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 0.8rem 1rem;
  font-family: var(--mono);
  font-size: 0.8rem;
  outline: none;
  transition: border-color 0.2s;
  resize: vertical;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus { border-color: var(--accent); }

.form-group select option { background: var(--bg); }

footer {
  position: relative;
  z-index: 1;
  border-top: 1px solid var(--border);
  padding: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}

footer p {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--muted);
}

.footer-sub { color: var(--muted); }

.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s, transform 0.6s;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 640px) {
  nav { padding: 1rem; }
  .nav-links { gap: 1.2rem; }
  .contact-wrap { grid-template-columns: 1fr; gap: 2rem; }
  .hero { padding-top: 6rem; }
}
